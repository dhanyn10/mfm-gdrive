{
  "name": "mfm-gdrive",
  "version": "3.0.0",
  "packageManager": "pnpm@10.32.1",
  "description": "MFM GDrive Desktop Application",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "npm-run-all --parallel dev:vite dev:electron",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron . --remote-debugging-port=9222",
    "build": "vite build",
    "start": "pnpm run build && electron .",
    "app:build": "pnpm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "app:dist": "pnpm run build && electron-builder --publish=never",
    "wdio": "wdio run ./wdio.conf.ts",
    "test": "vitest",
    "coverage": "vitest run --coverage"
  },
  "build": {
    "appId": "com.dhanyn.mfmgdrive",
    "productName": "MFM GDrive",
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "dhanyn10",
        "repo": "mfm-gdrive"
      }
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "dist-vite/**/*",
      "src/main/**/*",
      "assets/**/*",
      "package.json",
      "credentials.json",
      "!**/*.ts",
      "!*.code-workspace",
      "!LICENSE.md",
      "!package-lock.json",
      "!e2e/",
      "!hooks/",
      "!angular.json",
      "!_config.yml",
      "!karma.conf.js",
      "!tsconfig.json",
      "!tslint.json",
      "!token.json",
      "!README.md"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": "deb",
      "category": "Utility"
    }
  },
  "repository": "https://github.com/dhanyn10/mfm-gdrive.git",
  "author": {
    "name": "Dhany Nurdiansyah",
    "email": "dhanyn.dhan@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/cli": "^4.1.16",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@wdio/cli": "^9.16.2",
    "@wdio/local-runner": "^9.16.2",
    "@wdio/mocha-framework": "^9.16.2",
    "@wdio/spec-reporter": "^9.16.2",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.0.12",
    "jsdom": "^29.0.1",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.58.2",
    "postcss-cli": "^11.0.0",
    "tailwindcss": "^4.2.3",
    "vite": "^6.4.1",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4",
    "wdio-electron-service": "^9.1.0"
  },
  "dependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "@reduxjs/toolkit": "^2.11.2",
    "bottleneck": "^2.19.5",
    "google-auth-library": "^10.6.1",
    "googleapis": "^171.4.0",
    "node-abi": "^4.14.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "toastify-js": "^1.12.0"
  }
}